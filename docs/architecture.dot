digraph G {
  graph [rankdir=TB, bgcolor="#F7FAFC", pad="0.35", nodesep="0.45", ranksep="0.55", splines=ortho, fontname="Helvetica"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, margin="0.18,0.12", color="#CBD5E1", penwidth=1.2];
  edge [color="#64748B", penwidth=1.5, arrowsize=0.8, fontname="Helvetica", fontsize=10];

  governance [label="Governance\nCatalog • Policies • Lineage", fillcolor="#FFFFFF", color="#CBD5E1"];
  cicd [label="CI/CD\nTests • IaC • Promotion", fillcolor="#FFFFFF", color="#CBD5E1"];
  security [label="Security\nSecrets • RBAC • Encryption", fillcolor="#FFFFFF", color="#CBD5E1"];

  sources [label="Data Sources\nAPIs • Files • CDC • SaaS", fillcolor="#E0F2FE", color="#38BDF8"];
  ingest [label="Ingestion & Orchestration\nBatch / Streaming Jobs", fillcolor="#DBEAFE", color="#60A5FA"];
  bronze [label="Raw Zone\nLanding / Audit", fillcolor="#EDE9FE", color="#A78BFA"];
  silver [label="Curated Zone\nQuality Rules • Standardization", fillcolor="#F3E8FF", color="#C084FC"];
  features [label="Feature Store\nTraining / Serving Features", fillcolor="#FAE8FF", color="#E879F9"];
  train [label="Model Training\nExperiments • Validation", fillcolor="#DCFCE7", color="#4ADE80"];
  registry [label="Model Registry\nVersioning • Approval", fillcolor="#D1FAE5", color="#34D399"];
  serve [label="Batch / API Scoring\nJobs • Endpoints", fillcolor="#ECFCCB", color="#A3E635"];
  monitor [label="Monitoring & Ops\nDrift • SLAs • Alerts", fillcolor="#FEF3C7", color="#F59E0B"];
  consumers [label="Consumers\nBI • Apps • Ops Teams", fillcolor="#FEE2E2", color="#F87171"];

  subgraph cluster_crosscut {
    label="Cross-cutting Controls";
    labelloc="t";
    fontsize=18;
    fontname="Helvetica-Bold";
    color="#CBD5E1";
    style="rounded,dashed";
    penwidth=1.2;
    governance; cicd; security;
  }

  subgraph cluster_platform {
    label="Enterprise AI Platform";
    labelloc="t";
    fontsize=18;
    fontname="Helvetica-Bold";
    color="#94A3B8";
    style="rounded,dashed";
    penwidth=1.2;

    { rank=same; sources; ingest; bronze; silver; features; train; registry; serve; monitor; }
  }

  sources -> ingest -> bronze -> silver -> features -> train -> registry -> serve -> monitor;
  serve -> consumers;
  monitor -> train [xlabel="feedback loop", color="#94A3B8", fontcolor="#475569", constraint=false];

  governance -> bronze [style=dashed, arrowhead=none];
  governance -> silver [style=dashed, arrowhead=none];
  governance -> features [style=dashed, arrowhead=none];
  cicd -> train [style=dashed, arrowhead=none];
  cicd -> registry [style=dashed, arrowhead=none];
  cicd -> serve [style=dashed, arrowhead=none];
  security -> ingest [style=dashed, arrowhead=none];
  security -> serve [style=dashed, arrowhead=none];
  security -> monitor [style=dashed, arrowhead=none];
}
